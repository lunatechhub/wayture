# ─────────────────────────────────────────────────────────────────────────────
# Wayture backend .env template
# Copy this file to `.env` and fill in the real values. Never commit `.env`.
# Rotate any key that ends up in git history or a chat transcript.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase service account (required for auth + Firestore).
# Path is resolved relative to wayture_backend/ if not absolute.
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json

# Google Maps Platform key (must start with AIza…).
# Enable these APIs on https://console.cloud.google.com → APIs & Services:
#   • Directions API
#   • Distance Matrix API
#   • Places API
#   • Geocoding API
#   • Maps SDK for Android   (Flutter app)
#   • Maps SDK for iOS       (Flutter app)
# Then restrict the key to your Android package + SHA-1 and, for the backend,
# restrict by IP. Leave blank to fall back to OSRM/Nominatim.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Groq API key for AI-generated traffic insights (must start with gsk_…).
# Get one at https://console.groq.com/keys — blank disables AI commentary.
GROQ_API_KEY=your_groq_api_key_here

# No keys needed for:
#   • OSRM routing (public server)
#   • Nominatim geocoding
#   • Open-Meteo weather
#   • OpenStreetMap tiles
